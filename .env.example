# ---------------------------------------------------------------------------
# SERVER-SIDE SECRETS  (set these in the Vercel dashboard, NOT in the repo)
# These never reach the browser. Copy to a local .env for `vercel dev`.
# ---------------------------------------------------------------------------

# Stripe — Developers → API keys (use TEST keys while building)
STRIPE_SECRET_KEY=sk_test_xxx

# Stripe — Developers → Webhooks → your endpoint → "Signing secret"
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Price IDs — created from your two Products (Agent + Enterprise)
# Look like: price_1AbcdE...  (NOT the product id prod_...)
AGENT_PRICE_ID=price_xxx
ENTERPRISE_PRICE_ID=price_xxx

# Supabase — Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# The SERVICE ROLE key (secret!). Used only by the webhook to update accounts.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Your deployed site URL, used to build Checkout success/cancel redirects.
# Locally this is http://localhost:3000
APP_URL=https://signdeployer.com
