# ---------------------------------------------------------------------------
# SERVER-SIDE SECRETS  (set these in the Netlify dashboard, NOT in the repo)
# These never reach the browser. Copy to a local .env for `netlify dev`.
# ---------------------------------------------------------------------------

# Stripe — Developers → API keys (use TEST keys while building)
STRIPE_SECRET_KEY=sk_test_xxx

# Stripe — Developers → Webhooks → your endpoint → "Signing secret"
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Price IDs — created from your two Products (Agent + Brokerage)
# Look like: price_1AbcdE...  (NOT the product id prod_...)
AGENT_PRICE_ID=price_xxx
AGENT_MONTHLY_PRICE_ID=price_xxx
ENTERPRISE_PRICE_ID=price_xxx

# Supabase — Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# The SERVICE ROLE key (secret!). Used only by the serverless functions.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Mapbox SERVER token — used only by /api/map to call the Geocoding /
# Directions / Matrix / Tilequery / Optimization APIs on behalf of signed-in
# subscribers (and the rate-limited demo). Keep it secret: create a dedicated
# token at https://account.mapbox.com/access-tokens/ . The PUBLIC pk. token in
# app.html is only for rendering map tiles and should be URL-restricted to
# your domain in the Mapbox dashboard.
MAPBOX_TOKEN=pk_or_sk_xxx

# Your deployed site URL, used to build Checkout success/cancel redirects.
# Locally this is http://localhost:8888 (netlify dev)
APP_URL=https://signdeployer.com
